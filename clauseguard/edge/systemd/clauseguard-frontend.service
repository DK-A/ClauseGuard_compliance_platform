[Unit]
Description=ClauseGuard Vite React Frontend Service
After=network-online.target clauseguard-backend.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/clauseguard/frontend
ExecStart=/usr/bin/npm run dev -- --host 0.0.0.0 --port 5173
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
